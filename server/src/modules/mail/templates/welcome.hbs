<html lang='en'>

<head>
  <meta charset='UTF-8' />
  <meta name='viewport' content='width=device-width, initial-scale=1.0' />
  <title>Welcome</title>
</head>

<body style='font-family: Arial, sans-serif; background: #f7f7f9; margin: 0; padding: 24px; color: #1f2937;'>
  <table role='presentation' width='100%' cellspacing='0' cellpadding='0'
    style='max-width: 600px; margin: 0 auto; background: #ffffff; border-radius: 8px; padding: 24px;'>
    <tr>
      <td>
        <h2 style='margin: 0 0 12px 0;'>Welcome to {{appName}}, {{name}}!</h2>
        <p style='margin: 0 0 12px 0;'>Your account is now verified and ready
          to use.</p>
        <p style='margin: 0 0 20px 0;'>Go to your dashboard to get started.</p>
        <a href='{{dashboardUrl}}'
          style='display: inline-block; padding: 10px 16px; background: #2563eb; color: #ffffff; text-decoration: none; border-radius: 6px;'>Open
          Dashboard</a>
      </td>
    </tr>
  </table>
</body>

</html>