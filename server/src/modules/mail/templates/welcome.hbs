<!DOCTYPE html>
<html>
<head>
    <meta charset='utf-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>Welcome to Classflow</title>
    <style>
        body {
            font-family: 'Roboto', Arial, sans-serif;
            background-color: #ffffff;
            margin: 0;
            padding: 0;
        }

        .wrapper {
            width: 100%;
            background-color: #ffffff;
            padding-bottom: 40px;
        }

        .container {
            max-width: 520px;
            width: 95%;
            margin: 40px auto;
            border: 1px solid #dadce0;
            border-radius: 8px;
            padding: 40px;
            box-sizing: border-box;
        }

        .logo {
            font-size: 25px;
            font-weight: 600;
            margin-bottom: 25px;
            text-align: center;
            display: block;
        }

        .logo span { display: inline-block; margin: 0 1px; }
        .logo span:nth-child(1) { color: #4285f4; }
        .logo span:nth-child(2) { color: #ea4335; }
        .logo span:nth-child(3) { color: #fbbc05; }
        .logo span:nth-child(4) { color: #4285f4; }
        .logo span:nth-child(5) { color: #34a853; }
        .logo span:nth-child(6) { color: #ea4335; }
        .logo span:nth-child(7) { color: #fbbc05; }
        .logo span:nth-child(8) { color: #4285f4; }
        .logo span:nth-child(9) { color: #34a853; }

        h1 {
            color: #202124;
            font-size: 24px;
            font-weight: 400;
            margin: 0 0 20px 0;
            text-align: center;
        }

        .divider {
            height: 1px;
            background-color: #dadce0;
            margin-bottom: 30px;
        }

        .greeting {
            font-size: 16px;
            color: #202124;
            font-weight: 500;
            margin-bottom: 15px;
        }

        .message {
            font-size: 14px;
            color: #3c4043;
            line-height: 1.6;
            margin-bottom: 30px;
        }

        /* Feature Points List */
        .feature-list {
            list-style: none;
            padding: 0;
            margin: 0 0 30px 0;
        }

        .feature-item {
            margin-bottom: 20px;
            padding-left: 20px;
            border-left: 3px solid #4285f4; /* Nexion/Google Blue Accent */
        }

        .feature-title {
            font-size: 15px;
            font-weight: 500;
            color: #202124;
            margin-bottom: 4px;
        }

        .feature-desc {
            font-size: 13px;
            color: #5f6368;
            line-height: 1.4;
        }

        .btn-container {
            text-align: center;
            margin: 35px 0;
        }

        .cta-button {
            background-color: #1a73e8;
            color: #ffffff !important;
            padding: 12px 30px;
            text-decoration: none;
            border-radius: 4px;
            font-size: 14px;
            font-weight: 500;
            display: inline-block;
        }

        .footer {
            margin-top: 30px;
            padding-top: 20px;
            border-top: 1px solid #f1f3f4;
            font-size: 12px;
            color: #70757a;
            text-align: center;
            line-height: 1.5;
        }
    </style>
</head>
<body>
    <div class="wrapper">
        <div class='container'>
            <div class='logo'>
                <span>C</span><span>l</span><span>a</span><span>s</span><span>s</span><span>f</span><span>l</span><span>o</span><span>w</span>
            </div>

            <h1>Welcome to Classflow</h1>

            <div class='divider'></div>

            <div class='greeting'>Hi {{name}},</div>

            <div class='message'>
                Your account is all set! You can now use <strong>Classflow</strong> to manage academic info, join classrooms, and stay updated with your classmates.
            </div>

            <div class="feature-list">
                <div class="feature-item" style="border-left-color: #fbbc05;">
                    <div class="feature-title">Academic Hub</div>
                    <div class="feature-desc">Access exam dates, viva schedules, and CT updates in one place.</div>
                </div>

                <div class="feature-item" style="border-left-color: #34a853;">
                    <div class="feature-title">Quick Join</div>
                    <div class="feature-desc">Use easy join codes to enter your teachers' classrooms instantly.</div>
                </div>

                <div class="feature-item" style="border-left-color: #4285f4;">
                    <div class="feature-title">Smart Profiles</div>
                    <div class="feature-desc">Manage your student or teacher profile and connect with groups.</div>
                </div>
            </div>

            <div class='btn-container'>
                <a href='{{dashboardUrl}}' class='cta-button'>Get Started</a>
            </div>

            <div class='footer'>
                You received this email because you recently signed up for a Classflow Account.
                <br /><br />
                © {{year}} {{appName}} Inc.
            </div>
        </div>
    </div>
</body>
</html>