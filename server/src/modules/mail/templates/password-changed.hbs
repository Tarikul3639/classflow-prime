<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Password Changed</title>
  <style>
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      line-height: 1.6;
      color: #333;
      margin: 0;
      padding: 0;
      background-color: #f4f4f4;
    }
    .container {
      max-width: 600px;
      margin: 40px auto;
      background: white;
      border-radius: 12px;
      overflow: hidden;
      box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    }
    .header {
      background: linear-gradient(135deg, #10b981 0%, #059669 100%);
      color: white;
      padding: 40px 30px;
      text-align: center;
    }
    .header h1 {
      margin: 0;
      font-size: 28px;
      font-weight: 700;
    }
    .content {
      padding: 40px 30px;
    }
    .greeting {
      font-size: 18px;
      font-weight: 600;
      color: #0f172a;
      margin-bottom: 20px;
    }
    .message {
      font-size: 15px;
      color: #64748b;
      margin-bottom: 20px;
      line-height: 1.6;
    }
    .info-box {
      background: #f0fdf4;
      border-left: 4px solid #10b981;
      padding: 15px;
      margin: 20px 0;
      border-radius: 6px;
    }
    .info-box p {
      margin: 5px 0;
      font-size: 14px;
      color: #064e3b;
    }
    .warning {
      background: #fef2f2;
      border-left: 4px solid #ef4444;
      padding: 15px;
      margin: 30px 0;
      border-radius: 6px;
    }
    .warning p {
      margin: 0;
      font-size: 14px;
      color: #991b1b;
    }
    .cta-button {
      display: inline-block;
      background: #399aef;
      color: white;
      padding: 12px 24px;
      text-decoration: none;
      border-radius: 8px;
      font-weight: 600;
      font-size: 14px;
      margin: 20px 10px;
    }
    .footer {
      background: #f8fafc;
      padding: 30px;
      text-align: center;
      border-top: 1px solid #e2e8f0;
    }
    .footer p {
      margin: 5px 0;
      font-size: 13px;
      color: #94a3b8;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>✅ Password Changed Successfully</h1>
    </div>
    
    <div class="content">
      <div class="greeting">Hi {{name}},</div>
      
      <p class="message">
        This is to confirm that your password for your {{appName}} account has been changed successfully.
      </p>
      
      <div class="info-box">
        <p><strong>Changed At:</strong> {{changedAt}}</p>
      </div>
      
      <p class="message">
        You can now sign in to your account using your new password.
      </p>
      
      <div style="text-align: center;">
        <a href="{{signinUrl}}" class="cta-button">Sign In Now →</a>
      </div>
      
      <div class="warning">
        <p><strong>⚠️ Didn't change your password?</strong> If you didn't make this change, please contact our support team immediately and secure your account.</p>
      </div>
      
      <div style="text-align: center; margin-top: 30px;">
        <a href="{{supportUrl}}" class="cta-button" style="background: #64748b;">Contact Support</a>
      </div>
    </div>
    
    <div class="footer">
      <p><strong>{{appName}}</strong></p>
      <p>© {{year}} {{appName}}. All rights reserved.</p>
    </div>
  </div>
</body>
</html>