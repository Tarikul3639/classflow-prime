<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Security Alert: Password Changed</title>
  <style>
    body {
      font-family: 'Roboto', Arial, sans-serif;
      background-color: #ffffff;
      margin: 0;
      padding: 0;
    }
    /* Logo-r letter coloring */
    .logo-text {
      font-size: 25px;
      font-weight: 600;
      text-decoration: none;
    }
    .c1 { color: #4285f4; }
    .c2 { color: #ea4335; }
    .c3 { color: #fbbc05; }
    .c4 { color: #34a853; }

    /* Button and UI elements */
    .cta-button {
      background-color: #1a73e8;
      color: #ffffff !important;
      padding: 10px 24px;
      text-decoration: none;
      border-radius: 4px;
      font-size: 14px;
      font-weight: 500;
      display: inline-block;
    }
    .details-box {
      border: 1px solid #f1f3f4;
      border-radius: 4px;
      padding: 15px;
      text-align: left;
    }
    .footer-text {
      font-size: 12px;
      color: #70757a;
      line-height: 1.5;
    }
  </style>
</head>
<body>
  <table width="100%" border="0" cellspacing="0" cellpadding="0" bgcolor="#ffffff">
    <tr>
      <td align="center" style="padding: 40px 10px;">
        
        <table width="100%" border="0" cellspacing="0" cellpadding="0" style="max-width: 520px; border: 1px solid #dadce0; border-radius: 8px;">
          <tr>
            <td align="center" style="padding: 40px;">
              
              <div style="margin-bottom: 25px; text-align: center;">
                <span class="logo-text">
                  <span class="c1">C</span><span class="c2">l</span><span class="c3">a</span><span class="c1">s</span><span class="c4">s</span><span class="c2">f</span><span class="c3">l</span><span class="c1">o</span><span class="c4">w</span>
                </span>
              </div>

              <h1 style="color: #202124; font-size: 24px; font-weight: 400; margin: 0 0 20px 0;">Security alert</h1>

              <div style="height: 1px; background-color: #dadce0; margin-bottom: 30px;"></div>

              <div style="text-align: left;">
                <p style="color: #202124; font-size: 16px; font-weight: 500; margin-bottom: 15px;">Your password was changed</p>
                
                <p style="font-size: 14px; color: #3c4043; line-height: 1.5; margin-bottom: 25px;">
                  Hi {{name}}, the password for your <strong>{{appName}}</strong> account was recently changed.
                </p>

                <div class="details-box">
                  <table width="100%" border="0" cellspacing="0" cellpadding="0">
                    <tr>
                      <td width="80" style="font-size: 14px; color: #3c4043; font-weight: 500;">When:</td>
                      <td style="font-size: 14px; color: #3c4043;">{{changedAt}}</td>
                    </tr>
                  </table>
                </div>

                <div style="margin: 35px 0;">
                  <a href="{{signinUrl}}" class="cta-button">Sign in</a>
                </div>

                <div style="border-top: 1px solid #f1f3f4; padding-top: 25px; margin-top: 10px;">
                  <p style="font-size: 13px; color: #202124; font-weight: 600; margin-bottom: 5px;">Check activity</p>
                  <p style="font-size: 13px; color: #70757a; margin: 0;">
                    If you didn't change your password, someone else might be using your account. Review your account activity to secure it.
                  </p>
                </div>

                <div style="margin-top: 35px;" class="footer-text">
                  You received this email to let you know about important changes to your {{appName}} Account and services.
                  <br><br>
                  © {{year}} Classflow Inc.
                </div>
              </div>

            </td>
          </tr>
        </table>

      </td>
    </tr>
  </table>
</body>
</html>