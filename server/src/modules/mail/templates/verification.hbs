<html>

  <head>
    <meta charset='utf-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>Password Reset Request</title>
    <style>
      body {
        font-family: 'Google Sans', Roboto, Arial, sans-serif;
        background-color: #ffffff;
        margin: 0;
        padding: 0;
        display: flex;
        justify-content: center;
      }

      .container {
        max-width: 520px;
        width: 95%;
        margin: 40px auto;
        border: 1px solid #dadce0;
        border-radius: 8px;
        padding: 40px;
      }

      /* Logo logic optimized for Emails */
      .logo {
        font-size: 25px;
        font-weight: 600;
        margin-bottom: 20px;
        text-align: center;
        /* Force center align */
        display: block;
        width: 100%;
      }

      /* Letter spacing jate span gulo eksathe thake */
      .logo span {
        display: inline-block;
        margin: 0 1px;
      }

      /* Google style colors */
      .logo span:nth-child(1) {
        color: #4285f4;
      }

      .logo span:nth-child(2) {
        color: #ea4335;
      }

      .logo span:nth-child(3) {
        color: #fbbc05;
      }

      .logo span:nth-child(4) {
        color: #4285f4;
      }

      .logo span:nth-child(5) {
        color: #34a853;
      }

      .logo span:nth-child(6) {
        color: #ea4335;
      }

      .logo span:nth-child(7) {
        color: #fbbc05;
      }

      .logo span:nth-child(8) {
        color: #4285f4;
      }

      .logo span:nth-child(9) {
        color: #34a853;
      }

      h1 {
        color: #202124;
        font-size: 24px;
        font-weight: 400;
        line-height: 1.3;
        margin: 0 0 24px 0;
        text-align: center;
      }

      .divider {
        height: 1px;
        background-color: #dadce0;
        margin-bottom: 30px;
      }

      .message {
        font-size: 14px;
        color: #3c4043;
        text-align: left;
        line-height: 1.5;
        margin-bottom: 25px;
      }

      .text-body {
        font-size: 14px;
        color: #3c4043;
        line-height: 1.6;
        margin-bottom: 20px;
      }

      .code-box {
        font-size: 36px;
        font-weight: 500;
        color: #202124;
        text-align: center;
        margin: 30px 0;
        letter-spacing: 4px;
        padding: 10px;
        background: #f8fafc;
        border-radius: 4px;
      }

      .security-note {
        font-size: 13px;
        color: #70757a;
        margin-top: 30px;
        padding-top: 20px;
        border-top: 1px solid #f1f3f4;
      }

      .footer {
        margin-top: 30px;
        font-size: 12px;
        color: #70757a;
        text-align: center;
      }
    </style>
  </head>

  <body>
    <div class='container'>
      <div class='logo'>
        <span>C</span><span>l</span><span>a</span><span>s</span><span
        >s</span><span>f</span><span>l</span><span>o</span><span>w</span>
      </div>

      <h1>{{title}}</h1>

      <div class='divider'></div>

      <div class='text-body'>
        Hi
        {{name}},
      </div>

      <div class='message'>
        {{appName}}
        received a request to use
        <strong>{{email}}</strong>
        as a verification email for the account
        <strong>{{username}}</strong>.
      </div>

      <div class='code-box'>
        {{code}}
      </div>

      <div class='text-body'>
        This code will expire in
        <strong>{{expirationMinutes}} minutes</strong>.
      </div>

      <div class='security-note'>
        <strong>Didn't request this?</strong><br />
        If you didn't make this request, someone else may be trying to access
        your account. You can safely ignore this email; no changes will be made
        without this code.
      </div>

      <div class='footer'>
        ©
        {{year}}
        {{appName}}
        Inc.
        <br />
        This email was sent to notify you about important security changes.
      </div>
    </div>
  </body>

</html>